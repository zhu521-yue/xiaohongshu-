# M1/M2 runtime mode
COLLECTOR_MODE=mock
ACCOUNT_STAGE=cold_start

# API guardrails.
# Empty token keeps local development auth disabled.
# Set a strong value before binding the API beyond localhost.
XHS_AGENT_API_TOKEN=

# Logging.
XHS_AGENT_LOG_DIR=data/logs
XHS_AGENT_LOG_LEVEL=INFO
XHS_AGENT_LOG_MAX_BYTES=1048576
XHS_AGENT_LOG_BACKUP_COUNT=5

# Run storage backend.
# json keeps the existing data/api_runs/*.json behavior.
# sqlite stores run records in one local SQLite database.
XHS_AGENT_RUN_STORE=json
XHS_AGENT_RUN_DB_PATH=data/xhs_agent.sqlite3

# Run queue backend.
# local keeps the current in-process worker behavior.
# sqlite persists queue jobs and requires scripts/run_worker.py to execute them.
XHS_AGENT_RUN_QUEUE=local
XHS_AGENT_QUEUE_DB_PATH=data/xhs_agent.sqlite3
XHS_AGENT_WORKER_ID=
XHS_AGENT_QUEUE_POLL_SECONDS=1
XHS_AGENT_QUEUE_MAX_ATTEMPTS=3
XHS_AGENT_QUEUE_LOCK_TIMEOUT_SECONDS=900

# Operation memory backend.
# json keeps memory/operation_history.json behavior.
# sqlite stores operation records in the local SQLite database.
XHS_AGENT_MEMORY_STORE=json
XHS_AGENT_MEMORY_DB_PATH=data/xhs_agent.sqlite3

# OpenAI-compatible LLM config.
# Keep LLM_MODEL_NAME=mock to use offline mock mode.
LLM_MODEL_NAME=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_IMAGE_TEXT_MAX_TOKENS=5000
LLM_VIDEO_MAX_TOKENS=4000
LLM_REVIEW_MAX_TOKENS=1200

# Spider_XHS read-only collector.
# Do not commit real cookies. Copy this file to .env and fill locally.
XHS_COOKIES_PC=
XHS_NOTE_LIMIT=3
XHS_COMMENTS_PER_NOTE=10
XHS_SORT_TYPE=2
XHS_MIN_NOTE_COMMENTS=1
XHS_MIN_NOTE_INTERACTION=10
XHS_MIN_DELAY_SECONDS=2
XHS_MAX_DELAY_SECONDS=5

# Creator platform adapter.
# Keep CREATOR_MODE=mock unless explicitly testing Spider_XHS creator APIs.
# XHS_CREATOR_COOKIES is the creator platform cookie from https://creator.xiaohongshu.com.
CREATOR_MODE=mock
XHS_CREATOR_COOKIES=
